#!/usr/bin/env ruby

processes = [
  ["web", "./bin/rails", "server", *ARGV],
  ["vite", "yarn", "dev"]
]

pids = processes.map do |name, *command|
  spawn(*command, out: $stdout, err: $stderr).tap do |pid|
    puts "Started #{name} with pid #{pid}"
  end
end

Signal.trap("INT") { pids.each { |pid| Process.kill("TERM", pid) rescue nil } }
Signal.trap("TERM") { pids.each { |pid| Process.kill("TERM", pid) rescue nil } }

Process.wait
status = $?.exitstatus || 0
pids.each { |pid| Process.kill("TERM", pid) rescue nil }
exit status
